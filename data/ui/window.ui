<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.18"/>
  <requires lib="Adw" version="1.7"/>
  <template class="PulsoWindow" parent="AdwApplicationWindow">
    <property name="default-width">1400</property>
    <property name="default-height">850</property>
    <property name="content">
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar">
            <child type="start"><object class="GtkButton" id="new_button"><property name="icon-name">document-new-symbolic</property><property name="tooltip-text" translatable="yes">New slide</property></object></child>
            <child type="start"><object class="GtkButton" id="open_button"><property name="icon-name">document-open-symbolic</property><property name="tooltip-text" translatable="yes">Open</property></object></child>
            <child type="start"><object class="GtkButton" id="save_button"><property name="icon-name">document-save-symbolic</property><property name="tooltip-text" translatable="yes">Save</property></object></child>
            <property name="title-widget"><object class="AdwWindowTitle" id="window_title"><property name="title" translatable="yes">Pulso</property></object></property>
            <child type="end"><object class="GtkMenuButton"><property name="icon-name">open-menu-symbolic</property><property name="menu-model">main_menu</property></object></child>
            <child type="end"><object class="GtkButton" id="present_button"><property name="icon-name">media-playback-start-symbolic</property><property name="tooltip-text" translatable="yes">Start presentation</property><style><class name="suggested-action"/></style></object></child>
          </object>
        </child>
        <property name="content">
          <object class="GtkBox"><property name="orientation">horizontal</property>
            <child><object class="GtkBox"><property name="orientation">vertical</property><property name="width-request">220</property><style><class name="slide-list"/></style><child><object class="GtkScrolledWindow"><property name="vexpand">true</property><property name="child"><object class="GtkListBox" id="slide_list"><property name="selection-mode">single</property><property name="margin-top">8</property><property name="margin-bottom">8</property></object></property></object></child><child><object class="GtkSeparator"/></child><child><object class="GtkBox"><property name="halign">center</property><property name="margin-top">8</property><property name="margin-bottom">8</property><child><object class="GtkButton" id="add_slide_button"><property name="icon-name">list-add-symbolic</property><property name="tooltip-text" translatable="yes">New slide</property><style><class name="circular"/><class name="suggested-action"/></style></object></child></object></child></object></child>
            <child><object class="GtkSeparator"><property name="orientation">vertical</property></object></child>
            <child><object class="GtkBox"><property name="orientation">vertical</property><property name="hexpand">true</property><child><object class="GtkBox" id="tool_box"><property name="halign">center</property><property name="spacing">6</property><property name="margin-top">6</property><property name="margin-bottom">6</property></object></child><child><object class="GtkOverlay" id="stage_overlay"><property name="vexpand">true</property><property name="hexpand">true</property><style><class name="stage-frame"/></style><property name="child"><object class="GtkDrawingArea" id="stage"><property name="hexpand">true</property><property name="vexpand">true</property><property name="focusable">true</property></object></property></object></child><child><object class="GtkExpander" id="notes_expander"><property name="label" translatable="yes">Presenter notes</property><property name="child"><object class="GtkScrolledWindow"><property name="min-content-height">100</property><property name="child"><object class="GtkTextView" id="notes_view"><property name="wrap-mode">word-char</property><property name="margin-start">12</property><property name="margin-end">12</property><property name="margin-top">8</property><property name="margin-bottom">8</property><style><class name="notes"/></style></object></property></object></property></object></child></object></child>
            <child><object class="GtkSeparator"><property name="orientation">vertical</property></object></child>
            <child><object class="GtkBox" id="inspector_box"><property name="orientation">vertical</property><property name="width-request">250</property><child><object class="GtkLabel"><property name="label" translatable="yes">Properties</property><property name="margin-top">12</property><property name="margin-bottom">12</property><attributes><attribute name="weight" value="bold"/></attributes></object></child><child><object class="GtkLabel" id="selection_label"><property name="label" translatable="yes">No selection</property><property name="wrap">true</property><property name="margin-start">12</property><property name="margin-end">12</property></object></child></object></child>
          </object>
        </property>
      </object>
    </property>
  </template>
  <menu id="main_menu">
    <section><item><attribute name="label" translatable="yes">Save as</attribute><attribute name="action">win.save-as</attribute></item><item><attribute name="label" translatable="yes">Export PDF</attribute><attribute name="action">win.export-pdf</attribute></item></section>
    <section><item><attribute name="label" translatable="yes">Preferences</attribute><attribute name="action">app.preferences</attribute></item></section>
  </menu>
</interface>
